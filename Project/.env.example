# =============================================================================
# Koseli Xpress — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Database (required)
# -----------------------------------------------------------------------------
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/koseli_xpress

# MongoDB Atlas (cloud) — always include database name /koseli_xpress:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/koseli_xpress?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Gemini AI (required for AI features: SEO, blog writer, support chat)
# Get your key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Super Admin (seeded to MongoDB on backend startup)
# Backend reads ADMIN_* or VITE_ADMIN_* — change before production!
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@koselixpress.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Super Admin
ADMIN_PASSCODE=0000
VITE_ADMIN_EMAIL=admin@koselixpress.com
VITE_ADMIN_PASSWORD=admin123
VITE_ADMIN_NAME=Super Admin

# Dedicated admin panel URL (not linked from the public store)
VITE_ADMIN_PATH=/admin

# -----------------------------------------------------------------------------
# Customer Google Login — Auth0 (recommended) OR direct Google OAuth
# -----------------------------------------------------------------------------

# Option A: Auth0 with Google social connection (recommended)
# 1. Create app at https://manage.auth0.com — type: Single Page Application
# 2. Enable Google social connection in Auth0 dashboard
# 3. Allowed Callback URLs: http://localhost:3000/auth/callback
# 4. Allowed Logout URLs: http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id

# Option B: Direct Google OAuth (backend handles token exchange)
# Redirect URI in Google Console: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Session signing secret for Google OAuth tokens (change in production)
AUTH_SESSION_SECRET=change-this-to-a-long-random-string

# -----------------------------------------------------------------------------
# Frontend → Backend (optional, defaults to localhost:3001 via Vite proxy)
# -----------------------------------------------------------------------------
# VITE_BACKEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Payment Gateways — eSewa, Khalti, Fonepay
# Credentials can also be set in Admin → Settings → Payment Gateways.
# .env values are used as defaults when admin fields are empty.
# -----------------------------------------------------------------------------

# eSewa (sandbox: EPAYTEST / 8g786g78h76h876h)
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8g786g78h76h876h
ESEWA_ENV=test
ESEWA_ENABLED=false

# Khalti KPG-2 Web Checkout (https://docs.khalti.com/khalti-epayment/)
# Sandbox: signup at test-admin.khalti.com — use live_secret_key from sandbox dashboard
# Test Khalti ID: 9800000000–9800000005 | MPIN: 1111 | OTP: 987654
# Production: keys from admin.khalti.com — set KHALTI_ENV=live
KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=
KHALTI_ENV=test
KHALTI_ENABLED=false

# Fonepay
FONEPAY_MERCHANT_CODE=
FONEPAY_USERNAME=
FONEPAY_PASSWORD=
FONEPAY_SECRET_KEY=
FONEPAY_STATIC_QR_URL=
FONEPAY_ENV=test
FONEPAY_ENABLED=false
